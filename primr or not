#include<stdio.h>
int main(){
    int var,isprime;
    printf("enter the number: ");
    scanf("%d",&var);
    for(int i=2;i<var/2;i++){
        isprime=1;
        if(var%i==0)
        {
            isprime=0;
            break;
        }
    }
    if(isprime==1){
        printf("%d is a prime number",var);
    }
    else{
        printf("%d is not a prime number",var);
    }
    return 0;
}
