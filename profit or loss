#include <stdio.h>
int main()
{
   int cp,sp,p;
   printf("enter the cost price");
   scanf("%d",&cp);
   printf("enter the selling price");
   scanf("%d",&sp);
   p=sp-cp;
   if(sp>cp){
       printf("the profit is %d ",p);
   }
   else if(sp<cp){
       printf("the loss is %d ",p);
   }
   else{
       printf(" no profit");
   }
   
}
