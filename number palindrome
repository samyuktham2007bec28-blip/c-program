#include <stdio.h>

int main() {
    int num,rev=0;
    printf("enter a number\n");
    scanf("%d",&num);
    int original=num;
    while(num>0){
        rev=(rev*10)+(num%10);
        num=num /10;
        
    }
    if(original==rev){
        printf("The given number  %d is a palindrome\n",original);
    }
    else{
       printf("the given number %d is not a palindrome\n",original);
   }    
}
